def use_attack(a, d, attack):
    a_name = a["Tokimon"]
    d_name = d["Tokimon"]

    category = move_dict[attack]["Attack"]
    power = move_dict[attack]["Power"]

    if category == "Status":
        dialogue([f"{a_name} STEPPED INTO THE GREY SPOT OF PROGRAMMING DISCLOSURES"])
        return

    if category == "Special":
        attack_stat = "Special Attack"
        defense_stat = "Special Defense"
    else:
        attack_stat = "Attack"
        defense_stat = "Defense"

    damage = int(power * base_stats[a_name][attack_stat] / base_stats[d_name][defense_stat])
    damage = max(0, damage)

    d["HP"] = max(0, d["HP"] - damage)
    dialogue(f"{a_name} used {attack}!")        
def run_turn(a, d, move, enemy_move):
    # Remember to add status, priority, PP, ect.
    # Also a and d are TEAMS not Tokimon, bit of a letdown really
    a_name = a["Tokimon"]
    d_name = d["Tokimon"]    
    if base_stats[a_name]["Speed"] > base_stats[d_name]["Speed"]:
        attack = move    
    elif base_stats[a_name]["Speed"] < base_stats[d_name]["Speed"]:
        attack = enemy_move
    else:
        attack = random.choice([enemy_move, move])    
    use_attack(a, d, attack)  
    if base_stats[a_name]["Speed"] > base_stats[d_name]["Speed"]:
        attack = move    
    elif base_stats[a_name]["Speed"] < base_stats[d_name]["Speed"]:
        attack = enemy_move
    else:
        attack = random.choice([enemy_move, move])    
    use_attack(d, a, attack)  
