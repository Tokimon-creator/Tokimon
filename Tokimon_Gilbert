def write(caption):
    font = pygame.font.SysFont("Courier", 24)
    words = caption.split()

    x = 40
    y = 550
    max_width = game.get_width()
    line_text = ""

    for word in words:
        test_line = line_text + word + " "
        test_surface = font.render(test_line, False, (255, 255, 255))

        if test_surface.get_width() <= max_width:
            line_text = test_line
        else:
            text = font.render(line_text, False, (255, 255, 255))
            game.blit(text, (x, y))
            y += 30
            line_text = word + " "

    text = font.render(line_text, False, (255, 255, 255))
    game.blit(text, (x, y))
