def faintedornot(Tokimon):
    return Tokimon["HP"] == 0
def type_check(d, move):
    move_type = move_dict[move]["Type"]
    opposing_type = base_stats[d]["Type"]
    second_type = base_stats[d]["Type2"]
    effect = 1
    if move_type in matchup[opposing_type]["Weaknesses"]:
        effect *= 2
    elif move_type in matchup[opposing_type]["Resistences"]:
        effect *= 0.5
    if move_type in matchup[second_type]["Weaknesses"]:
        effect *= 2
    elif move_type in matchup[second_type]["Resistences"]:
        effect *= 0.5
    return effect            
