while on:
    for event in pygame.event.get():
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_a: 
                if line < len(speech) - 1:
                    line += 1
                elif speech == intro:
                    line = 0
                    dialogue(trip)
                elif speech == trip:
                    line = 0
                    dialogue(lab) 
            if event.key == pygame.K_MINUS:
                Tokidex()      
            if event.key == pygame.K_1:
                starter = "Sickorita"
            if event.key == pygame.K_2:
                starter = "Dynaquill"
            if event.key == pygame.K_3:
                starter = "Botodile"
            if event.key == pygame.K_4:
                starter = "Tichu"
        if event.type == pygame.KEYDOWN and mode == "Battle":
            active = team[team_slot]["Tokimon"]
            moves = base_stats[active]["movepool"]["Level 1"]

            if event.key == pygame.K_UP:
                move_slot = (move_slot - 1) % len(moves)

            elif event.key == pygame.K_DOWN:
                move_slot = (move_slot + 1) % len(moves)

            elif event.key == pygame.K_RETURN:
                player_mon = team[team_slot]
                enemy_mon = enemy_team[enemy_slot]
                chosen_move = moves[move_slot]
                enemy_name = enemy_mon["Tokimon"]
                oppose = random.choice(base_stats[enemy_name]["movepool"]["Level 1"])
                run_turn(player_mon, enemy_mon, chosen_move, oppose)
        if event.type == pygame.QUIT:
            on = False   
    keys = pygame.key.get_pressed()                                
    t.tick(60)
    game.fill((0, 0, 0))
    if inside_lab == True or outside == True or speech == lab:
        if not outside:
            if starter_picked == False:
                Tokimon = "" 
            draw_lab()
        else:
            draw_outside()   
        if mode != "Battle":     
            game.blit(player, (player_x, player_y))
        if keys[pygame.K_UP]:
            if mode == "Overworld":
                player_y -= 10
            else: send_out()
        elif keys[pygame.K_DOWN]:
            if mode == "Overworld":
                player_y += 10
        elif keys[pygame.K_LEFT]:
            if mode == "Overworld":
                player_x -= 10
            else: send_left()  
        elif keys[pygame.K_RIGHT]:
            if mode == "Overworld":
                player_x += 10
            else: send_right()
        if event.type == pygame.QUIT:
            on = False           
    else:
        game.fill((80, 180, 255))
    if line == 0 and speech[line] == "Tokimon in the ocean, surfers in the seas...":
