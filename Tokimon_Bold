def use_attack(a, d, attack):
    global mode
    a_name = a["Tokimon"]
    d_name = d["Tokimon"]

    if a["PP"][attack] == 0:
        return [[f"{a_name} tried to use {attack}!", False, ["But it failed!"]]]

    if random.randint(1, 4) == 1 and a["Status"] == "Paralyzed":
        return [[f"{a_name} was fully paralyzed!"], False, [f"{a_name} was unable to attack!"]]

    category = move_dict[attack]["Attack"]
    power = move_dict[attack]["Power"]
    if category == "Special":
        d_stage = stage_multiplier[d["Special Defense Stage"]]
    else: 
        d_stage = stage_multiplier[d["Defense Stage"]]    
    if category == "Special":    
        a_stage = stage_multiplier[a[category + " Attack Stage"]]
    else:
        a_stage = stage_multiplier[a["Attack Stage"]]    

    if category == "Special":
        attack_stat = "Special Attack"
        defense_stat = "Special Defense"
    else:
        attack_stat = "Attack"
        defense_stat = "Defense"
    if category != "Status":
        damage = int((power * base_stats[a_name][attack_stat] / base_stats[d_name][defense_stat]) * a_stage/d_stage)
        damage = max(0, damage)
    else:
        damage = 0
    a["PP"][attack] -= 1        
    aplier = type_check(d_name, attack)    
    damage *= aplier
    if aplier == 2:
        message = "super-effective!"
    elif aplier == 4:
        message = "extremely effective!"    
    elif aplier == 0.5:
        message = "not very effective."
    elif aplier == 0.25:
        message = "mostly ineffective."
    else:
        message = "something that should not be dialogue at this point."            
    d["HP"] = max(0, d["HP"] - damage)
    thing = [""]
    if move_dict[attack]["Effect"] == "Lowers attack":
        d["Attack Stage"] -= 1
        thing = [f"{d_name}'s attack was lowered!"]
    elif move_dict[attack]["Effect"] == "Lowers Defense":
        d["Defense Stage"] -= 1    
        thing = [f"{d_name}'s defense was lowered!"]
    elif move_dict[attack]["Effect"] == "Chance of paralyzation":
        if random.randint(1, 20) in [1,2,3]:
            d["Status"] = "Paralyzed"   
            d["Current Speed"] *= 1/2 
            thing = [f"{d_name} was paralyzed by {attack}!"]
    fainted = faintedornot(d)
    if fainted == True:
        mode = "Overworld"
        return [[f"{d_name} fainted!"], True, thing]
    else:
        return [[f"{a_name} used {attack}! It was {message}"], False, thing]
def run_turn(a, d, move, enemy_move):
    # Also a and d are TEAMS not Tokimon, bit of a letdown really
    messages = []
    a_name = a["Tokimon"]
    d_name = d["Tokimon"]    
    if move_dict[enemy_move]["Priority"] > move_dict[move]["Priority"]:
        attack = enemy_move
        faster = d
    elif move_dict[enemy_move]["Priority"] < move_dict[move]["Priority"]:
        attack = move
        faster = a    
    else:    
        if base_stats[a_name]["Speed"] > base_stats[d_name]["Speed"]:
            attack = move  
            faster = a  
        elif base_stats[a_name]["Speed"] < base_stats[d_name]["Speed"]:
            attack = enemy_move
            faster = d
        else:
            attack = random.choice([enemy_move, move]) 
            faster = random.choice([a, d]) 
    if faster == a:
        slower = d
    else:
        slower = a
    thing1 = use_attack(faster, slower, attack)
    if attack == enemy_move:
        attack = move
    else:
        attack = enemy_move    
    thing2 = use_attack(slower, faster, attack)  
    messages += thing1[0]
    messages += thing1[2]
    if thing1[1]:
        dialogue(messages)
        return                 
    messages += thing2[0]
    messages += thing2[2]
    if thing2[1]:
        dialogue(messages)
        return
    dialogue(messages)    
