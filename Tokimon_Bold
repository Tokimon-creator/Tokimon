    elif line == 1 and speech[line] == "Tokimon on the ground, unfortunate trainers on the floor...":
        pygame.draw.rect(game,  (170, 150, 150),  (0, 350, 1200, 370))  
    elif line == 2 and speech[line] == "Tokimon in the air, one VERY unlucky trainer on an airplane.":
